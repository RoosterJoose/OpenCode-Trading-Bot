{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "hermes-freqtrade-lab",
  "initial_state": "stopped",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "max_open_trades": 3,
  "stake_currency": "USDC",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "timeframe": "1h",
  "fiat_display_currency": "USD",
  "cancel_open_orders_on_exit": true,
  "process_only_new_candles": true,
  "minimal_roi": {},
  "stoploss": -0.04,
  "use_exit_signal": true,
  "ignore_roi_if_entry_signal": false,
  "order_types": {
    "entry": "market",
    "exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },
  "order_time_in_force": {
    "entry": "gtc",
    "exit": "gtc"
  },
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": false,
    "price_last_balance": 0.0
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": false,
    "price_last_balance": 0.0
  },
  "exchange": {
    "name": "hyperliquid",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "options": {
        "defaultType": "swap"
      }
    },
    "ccxt_async_config": {
      "options": {
        "defaultType": "swap"
      }
    },
    "pair_whitelist": [
      "BTC/USDC:USDC",
      "ETH/USDC:USDC",
      "SOL/USDC:USDC"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "api_server": {
    "enabled": false,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8082,
    "username": "freqtrade",
    "password": "freqtrade"
  },
  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": ""
  },
  "internals": {
    "process_throttle_secs": 5,
    "heartbeat_interval": 60
  },
  "strategy": "HermesPerpStrategy"
}
